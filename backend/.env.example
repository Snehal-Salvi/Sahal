PORT=5001
MONGODB_URI=mongodb://127.0.0.1:27017/cartoon-filter
FRONTEND_URL=http://localhost:5173
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_URL=
AI_SERVICE_URL=http://127.0.0.1:8000
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
JWT_SECRET=replace-with-32-plus-bytes-of-random-base64
JWT_EXPIRES_IN=7d
OVERLAY_ALLOWED_HOSTS=res.cloudinary.com
# Shared secret between backend and AI service. Generate with `openssl rand -base64 32`.
# Must match AI_SERVICE_SECRET in ai-service/.env.
AI_SERVICE_SECRET=replace-with-32-plus-bytes-of-random-base64
# Set to "production" on prod deploys to enable HTTPS redirect + Mongo TLS check.
NODE_ENV=development
# Optional — leave blank to disable error reporting.
SENTRY_DSN=
